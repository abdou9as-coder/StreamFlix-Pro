<?xml version="1.0" encoding="UTF-8" ?>
<b:template xmlns='http://www.w3.org/1999/xhtml'
xmlns:b='http://www.google.com/2005/gml/b'
xmlns:data='http://www.google.com/2005/gml/data'
xmlns:expr='http://www.google.com/2005/gml/expr'>

<html dir='rtl' lang='ar'>

<head>

<meta charset='UTF-8'/>
<meta content='width=device-width,initial-scale=1' name='viewport'/>

<title><data:blog.pageTitle/></title>

<b:skin><![CDATA[
/* سيتم نقل جميع ملفات CSS هنا لاحقاً */
]]></b:skin>

</head>

<body>
  <b:section id='ThemeSettings'
           maxwidgets='1'
           showaddelement='yes'/>

  
<header class='sf-header'>

<div class='container navbar'>

<a class='logo'
expr:href='data:blog.homepageUrl'>

<data:blog.title/>

</a>

<nav>

<ul class='menu'>

<li>

<a expr:href='data:blog.homepageUrl'>

الرئيسية

</a>

</li>

<li>

<a href='/search/label/مسلسلات'>

المسلسلات

</a>

</li>

<li>

<a href='/search/label/أفلام'>

الأفلام

</a>

</li>

<li>

<a href='/search/label/أنمي'>

الأنمي

</a>

</li>

</ul>

</nav>

<div class='actions'>

<button id='themeToggle'>

🌙

</button>

<button id='searchButton'>

🔍

</button>

</div>

</div>

</header>

<section class='hero'>

<div class='container'>

<b:section id='HeroSlider'
showaddelement='yes'
maxwidgets='1'/>

</div>

</section>

<section class='container'>

<h2>

أحدث المسلسلات

</h2>

<div class='grid'>

<b:loop values='data:posts'
var='post'>

<article class='movie-card'>

<a expr:href='data:post.url'>

<img expr:src='data:post.firstImageUrl'/>

<h3>

<data:post.title/>

</h3>

</a>

</article>

</b:loop>

</div>

</section>
    
<header class='header'>

<div class='container navbar'>

<a class='logo' expr:href='data:blog.homepageUrl'>
<data:blog.title/>
</a>

<ul class='menu'>

<li><a expr:href='data:blog.homepageUrl'>الرئيسية</a></li>

<li><a href='/search/label/مسلسلات'>المسلسلات</a></li>

<li><a href='/search/label/أفلام'>الأفلام</a></li>

<li><a href='/search/label/أنمي'>الأنمي</a></li>

</ul>

<div class='actions'>

<button id='themeToggle' class='icon-btn'>🌙</button>

<button class='icon-btn'>🔍</button>

</div>

</div>

</header>

<section class='hero'>

<div class='container hero-content'>

<h2>شاهد أحدث المسلسلات</h2>

<p>
أفضل منصة مبنية على بلوجر لمشاهدة المسلسلات والأفلام.
</p>

<a class='watch-btn' href='#latest'>

ابدأ المشاهدة

</a>

</div>

</section>

<section id='latest' class='container'>

<h2>أحدث الإضافات</h2>

<div class='grid'>

<b:loop values='data:posts' var='post'>

<article class='movie-card'>

<a expr:href='data:post.url'>

<div class='movie-thumb'>

<img expr:src='data:post.firstImageUrl'/>

<div class='movie-overlay'/>

<div class='movie-info'>

<h3 class='movie-title'>

<data:post.title/>

</h3>

<div class='movie-meta'>

<span>
<data:post.dateHeader/>
</span>

</div>

</div>

</div>

</a>

</article>

</b:loop>

</div>

</section>

<section class='container'>

<h2>الأكثر مشاهدة</h2>

<b:section id='Popular'
showaddelement='yes'
maxwidgets='1'/>

</section>

<footer>

<div class='container'>

<p>

© <data:blog.title/>

</p>

</div>

</footer>

</body>

</html>

</b:template>
